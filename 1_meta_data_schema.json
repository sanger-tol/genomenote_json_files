{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "properties": {
        "metadata": {
            "type": "object",
            "properties": {
                "doi": {
                    "type": "string"
                },
                "data_availability": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "abstract": {
                    "type": "string"
                },
                "keywords": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "background": {
                    "type": "string"
                },
                "bioproject": {
                    "type": "string",
                    "help": "Main or umbrella BioProject for the genome note."
                },
                "child_bioprojects": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "help": "Child BioProjects associated with the main BioProject; used by data_note to find sequencing run metadata."
                },
                "parent_projects": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "accession": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string"
                            },
                            "project_name": {
                                "type": "string"
                            },
                            "title": {
                                "type": "string"
                            }
                        }
                    },
                    "help": "Parent BioProjects associated with the main BioProject. Used by data_note to derive formatted_parent_projects."
                },
                "formatted_parent_projects": {
                    "type": "string",
                    "help": "Publication-ready parent project string derived from parent_projects by data_note. Describes, e.g. Project Psyche."
                },
                "authors": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "surname": {
                                "type": "string"
                            },
                            "given_names": {
                                "type": "string"
                            },
                            "roles": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "orcid": {
                                "type": "string"
                            },
                            "corresponding": {
                                "type": "boolean"
                            },
                            "affiliations": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                },
                "affiliations": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "id": {
                                "type": "string"
                            },
                            "affiliation": {
                                "type": "string"
                            }
                        }
                    }
                }
            },
            "required": [
                "doi",
                "title"
            ]
        },
        "software_tools": {
            "type": "array",
            "$comment": "KvN: Software tools describe methods rather than article-level metadata, so they may belong with methods/analysis or in a dedicated software section.",
            "items": {
                "type": "object",
                "properties": {
                    "software_tool": {
                        "type": "string"
                    },
                    "version": {
                        "type": "string"
                    },
                    "source": {
                        "type": "string"
                    }
                }
            }
        },
        "publication_metadata": {
            "type": "object",
            "$comment": "KvN: Some fields, e.g. e_location_id, are journal-specific. Other publication-level fields such as licence, funding and competing interests may still be needed by a publication portal; the portal metadata model needs to be defined separately from genome-note scientific metadata.",
            "properties": {
                "funding": {
                    "type": "array",
                    "items": {
                        "type": "object",
                        "properties": {
                            "source": {
                                "type": "string"
                            },
                            "award_ids": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                }
                            },
                            "funding_statement": {
                                "type": "string"
                            }
                        }
                    }
                },
                "e_location_id": {
                    "type": "string"
                },
                "license": {
                    "type": "string"
                },
                "ebp_analysis_metrics": {
                    "type": "array"
                },
                "submission_date": {
                    "type": "string"
                },
                "publication_date": {
                    "type": "string"
                },
                "acknowledgements": {
                    "type": "string"
                },
                "ethics_and_consent": {
                    "type": "object"
                },
                "competing_interests": {
                    "type": "string"
                }
            }
        }
    }
}
