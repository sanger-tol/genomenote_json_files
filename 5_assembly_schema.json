{
    "$schema": "https://json-schema.org/draft/2020-12/schema#",
    "type": "object",
    "$comment": "KvN: Assembly needs an explicit assembly_role concept: primary, alternate, hap1, hap2. These are linked to analyses and to decision points in the genome note template about what is included.",
    "properties": {
        "assembly_methods": {
            "type": "object",
            "$comment": "KvN: Assembly methods and curation methods are related but not the same. Assembly methods describe how the assembly was generated, scaffolded and purged before or during production of the submitted assembly.",
            "properties": {
                "assembly_method_text": {
                    "type": "string",
                    "help": "Publication-ready or template-generated text describing the assembly method."
                },
                "assembly_pipeline": {
                    "type": "string",
                    "help": "Assembly pipeline or workflow used, where recorded separately from individual software tools."
                },
                "assembly_software": {
                    "type": "array",
                    "help": "Software used for assembly generation, scaffolding or purging, for example Hifiasm, purge_dups or YaHS.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "name": {
                                "type": "string"
                            },
                            "version": {
                                "type": "string"
                            },
                            "purpose": {
                                "type": "string"
                            },
                            "parameters": {
                                "type": "string"
                            },
                            "source": {
                                "type": "string"
                            }
                        }
                    }
                },
                "hifiasm_phasing_mode": {
                    "enum": [
                        "hic_phasing",
                        "original",
                        "other"
                    ],
                    "help": "Whether Hifiasm was run in Hi-C phasing mode or original/non-Hi-C mode."
                },
                "hifiasm_options": {
                    "type": "string",
                    "help": "Hifiasm command-line options where these affect the published assembly method, for example --primary -l0."
                },
                "hifiasm_primary_mode": {
                    "type": "boolean",
                    "help": "Whether Hifiasm primary mode was used."
                },
                "hifiasm_internal_purging_disabled": {
                    "type": "boolean",
                    "help": "Whether Hifiasm internal purging was disabled."
                },
                "hifiasm_options_sentence": {
                    "type": "string",
                    "help": "Publication-ready sentence derived from Hifiasm options by data_note."
                },
                "organelle_assembly": {
                    "type": "array",
                    "help": "Organelle assembly steps or decisions, including assembler and comparator where relevant.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "organelle_type": {
                                "enum": [
                                    "mitochondrion",
                                    "plastid",
                                    "chloroplast",
                                    "other"
                                ]
                            },
                            "assembler": {
                                "type": "string",
                                "help": "Tool or workflow used for organelle assembly, for example MitoHiFi or Oatk."
                            },
                            "comparator": {
                                "type": "string",
                                "help": "Comparator species, assembly or reference used for organelle assembly, where applicable."
                            },
                            "comparator_accession": {
                                "type": "string"
                            },
                            "decision_notes": {
                                "type": "string",
                                "help": "Short note on organelle assembly choices or review decisions."
                            }
                        }
                    }
                },
                "microchromosome_assignment": {
                    "type": "object",
                    "help": "Method or decision fields used for identifying or assigning bird microchromosomes, where relevant.",
                    "properties": {
                        "tool": {
                            "type": "string",
                            "help": "Tool or workflow used for microchromosome identification or assignment, for example MicroFinder."
                        },
                        "version": {
                            "type": "string"
                        },
                        "comparator": {
                            "type": "string",
                            "help": "Comparator species, assembly or reference used for microchromosome assignment, where applicable."
                        },
                        "comparator_accession": {
                            "type": "string"
                        },
                        "decision_notes": {
                            "type": "string",
                            "help": "Short note on microchromosome assignment choices or review decisions."
                        }
                    }
                }
            }
        },
        "assembly_stats": {
            "type": "object",
            "properties": {
                "assembly_information": {
                    "type": "object",
                    "properties": {
                        "id": "string",
                        "assembly_level": {
                            "enum": [
                                "contig",
                                "scaffold",
                                "chromosome"
                            ]
                        },
                        "assembly_accession": {
                            "type": "string"
                        },
                        "assembly_id": {
                            "type": "string"
                        },
                        "no_of_contigs": {
                            "type": "integer"
                        },
                        "contig_n50_length": {
                            "type": "number"
                        },
                        "no_of_scaffolds": {
                            "type": "integer"
                        },
                        "scaffold_n50_length": {
                            "type": "number"
                        },
                        "longest_scaffold_length": {
                            "type": "number"
                        },
                        "genome_size": {
                            "type": "number"
                        },
                        "perc_assembled": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "help": "Percentage of the primary assembly assigned to chromosomes, as calculated by data_note from assembly chromosome lengths."
                        },
                        "hap1_perc_assembled": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "help": "Percentage of haplotype 1 assigned to chromosomes, as calculated by data_note from assembly chromosome lengths."
                        },
                        "hap2_perc_assembled": {
                            "type": "number",
                            "minimum": 0,
                            "maximum": 100,
                            "help": "Percentage of haplotype 2 assigned to chromosomes, as calculated by data_note from assembly chromosome lengths."
                        }
                    }
                },
                "organelles": {
                    "type": "array",
                    "$comment": "KvN: data_note reports organelles as assembly products, including mitochondrial and plastid records from NCBI Datasets sequence reports.",
                    "help": "Organelle sequences included in the assembly, such as mitochondrial and plastid genomes.",
                    "items": {
                        "type": "object",
                        "properties": {
                            "assembly_role": {
                                "enum": [
                                    "primary",
                                    "alternate",
                                    "hap1",
                                    "hap2"
                                ],
                                "help": "Assembly role containing this organelle record."
                            },
                            "organelle_type": {
                                "enum": [
                                    "mitochondrion",
                                    "plastid",
                                    "chloroplast"
                                ]
                            },
                            "accession": {
                                "type": "string"
                            },
                            "name": {
                                "type": "string",
                                "help": "Molecule name, for example MT or PLTD."
                            },
                            "description": {
                                "type": "string"
                            },
                            "length_kb": {
                                "type": "number",
                                "minimum": 0
                            },
                            "gc_percent": {
                                "type": "number",
                                "minimum": 0,
                                "maximum": 100
                            }
                        }
                    }
                }
            }
        },
        "assembly_analysis": {
            "type": "object",
            "properties": {
                "ncbi_taxonomy_id": {
                    "type": "string",
                    "minLength": 1
                },
                "ploidy": {
                    "method": {
                        "type": "object",
                        "properties": {
                            "software": "string",
                            "doi": "string"
                        }
                    },
                    "count": {
                        "type": "number",
                        "help": "Ploidy count"
                    },
                    "english_count": {
                        "type": "string",
                        "help": "Whether the count equates to diploid, triploid, etc."
                    }
                },
                "kmer_analysis": {
                    "type": "array",
                    "properties": {
                        "name": {
                            "enum": [
                                "genomescope",
                                "smudgeplot"
                            ]
                        },
                        "path": {
                            "type": "string",
                            "help": "Path to directory containing results"
                        },
                        "est_size_bp": {
                            "type": "number",
                            "minimum": 0,
                            "help": "Estimated length of assembly from analysis, recorded in base-pairs"
                        }
                    }
                },
                "merqury TB: I suggest removing this from here and leaving/placing in the analysis schema": {
                    "type": "array",
                    "properties": {
                        "assembly_id": "string",
                        "haplotype": {
                            "type": "string",
                            "help": "Tool can be run once per haplotype + for a combined assembly. Every time, there will be overall AND per hap results.",
                            "reads_used": {
                                "type": "array",
                                "properties": {
                                    "file_path": "string"
                                }
                            }
                        },
                        "kmer_length": {
                            "type": "integer",
                            "minimum": 0,
                            "help": "Length of the kmer used for analysis"
                        },
                        "statistics": {
                            "type": "object",
                            "properties": {
                                "qv_files": {
                                    "type": "array",
                                    "help": "All *.qv files"
                                },
                                "completeness_stats": "string",
                                "spectra_plots": {
                                    "type": "array",
                                    "help": "multiple files are produced for spectra (ln, fl and st)."
                                },
                                "only_bed": {
                                    "type": "string",
                                    "help": "The *only.bed file"
                                }
                            }
                        }
                    }
                },
                "busco TB: as above, leave this in the analysis schema only": {
                    "type": "array",
                    "properties": {
                        "lineages": {
                            "odb_name": "string",
                            "complete": {
                                "type": "number",
                                "minimum": 0,
                                "help": "Percentage of complete busco genes"
                            },
                            "single": {
                                "type": "number",
                                "minimum": 0,
                                "help": "Percentage of single busco genes"
                            },
                            "duplicate": {
                                "type": "number",
                                "minimum": 0,
                                "help": "Percentage of duplicate busco genes"
                            }
                        }
                    },
                    "raw_data_object": {
                        "type": "array",
                        "help": "Linked to raw_data in sample_prep_schema",
                        "properties": {
                            "accession": "string",
                            "data_type": "string"
                        }
                    },
                    "chromosome_tables": {
                        "help": "Chromosomal pseudomolecules",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "insdc_accession": {
                                    "type": "string"
                                },
                                "chromosome": {
                                    "type": "string"
                                },
                                "size_mb": {
                                    "type": "number"
                                },
                                "gc_percent": {
                                    "type": "number"
                                }
                            }
                        }
                    },
                    "samples": {
                        "type": "array",
                        "$comment": "KvN: This is used in the Samples acquisition section of the genome note and belongs to 3_sample_prep_methods_schema.json rather to the assembly schema",
                        "items": {
                            "type": "object",
                            "properties": {
                                "biosample_id": {
                                    "help": "Data taken from ENA",
                                    "type": "string"
                                },
                                "collector_institute": {
                                    "type": "string"
                                },
                                "gal": {
                                    "type": "string"
                                },
                                "collection_date": {
                                    "type": "string"
                                },
                                "collection_location": {
                                    "type": "string"
                                },
                                "sample_derived_from": {
                                    "type": "string"
                                },
                                "sex": {
                                    "type": "string"
                                },
                                "lifestage": {
                                    "type": "string"
                                },
                                "tolid": {
                                    "type": "string"
                                },
                                "specimen_images": {
                                    "type": "array",
                                    "items": {
                                        "type": "object",
                                        "properties": {
                                            "image": {
                                                "type": "string"
                                            },
                                            "link": {
                                                "type": "string"
                                            },
                                            "caption": {
                                                "type": "string"
                                            }
                                        }
                                    }
                                }
                            },
                            "required": [
                                "ncbi_taxonomy_id"
                            ]
                        }
                    },
                    "taxonomy": {
                        "help": "Was species",
                        "type": "array",
                        "items": {
                            "type": "object",
                            "properties": {
                                "tax_authority": "string",
                                "ncbi_taxonomy_id": {
                                    "type": "string",
                                    "minLength": 1
                                },
                                "lineage": {
                                    "type": "string"
                                },
                                "class": {
                                    "type": "string"
                                },
                                "family": {
                                    "type": "string"
                                },
                                "order": {
                                    "type": "string"
                                },
                                "phylum": {
                                    "type": "string"
                                },
                                "common_name": {
                                    "type": "string",
                                    "help": "Common name used in the genome note. In data_note this is taken from GBIF when available, or NCBI Datasets as fallback."
                                },
                                "common_name_source": {
                                    "enum": [
                                        "gbif",
                                        "ncbi_datasets"
                                    ],
                                    "help": "Source used for common_name."
                                },
                                "species": {
                                    "type": "string"
                                }
                            },
                            "required": [
                                "ncbi_taxonomy_id"
                            ]
                        }
                    }
                }
            }
        }
    }
}
